            "def _generate_interrupt_state_fields(isa_data: Dict[str, Any]) -> str:
                """Generate interrupt-related state fields based on interrupt model."""
                model = resolve_interrupt_model(isa_data)

                if model == "none":
                    return "    /* Interrupt model: none */"

                lines = []
