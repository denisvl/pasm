      comp->atari_cas_pending_byte = 0xFFu;
      comp->atari_cas_current_kind = 1u;
      comp->atari_cas_current_byte = 0xFFu;
      {
          const char *poll_env = getenv("PASM_COCO_POLL_TRACE");
          if (poll_env != NULL && poll_env[0] != '\0' && poll_env[0] != '0') {
              const char *poll_path = getenv("PASM_COCO_POLL_TRACE_FILE");
              if (poll_path == NULL || poll_path[0] == '\0') poll_path = "/tmp/coco_poll_trace.log";
              FILE *fp = fopen(poll_path, "w");
              if (fp != NULL) fclose(fp);
          }
      }
      {
          const char *trace_env = getenv("PASM_COCO_TAPE_TRACE");
          if (trace_env != NULL && trace_env[0] != '\0' && trace_env[0] != '0') {
              const char *trace_path = getenv("PASM_COCO_TAPE_TRACE_FILE");
              if (trace_path == NULL || trace_path[0] == '\0') trace_path = "/tmp/coco_tape_trace.log";
              FILE *fp = fopen(trace_path, "w");
              if (fp != NULL) fclose(fp);
          }
      }
    destroy: |
      if (comp->record_fp != NULL) {
          FILE *fp = (FILE *)comp->record_fp;
          uint32_t riff_size = 36u + comp->record_bytes;
          uint32_t data_size = comp->record_bytes;
          fseek(fp, 4, SEEK_SET);
          fwrite(&riff_size, 1, 4, fp);
          fseek(fp, 40, SEEK_SET);
          fwrite(&data_size, 1, 4, fp);
          fclose(fp);
          comp->record_fp = NULL;
      }
      if (comp->wav_data != NULL) {
          free(comp->wav_data);
          comp->wav_data = NULL;
      }
      if (comp->wav_filtered_mono != NULL) {
          free(comp->wav_filtered_mono);
          comp->wav_filtered_mono = NULL;
      }
      if (comp->direct_edge_positions != NULL) {
          free(comp->direct_edge_positions);
          comp->direct_edge_positions = NULL;
      }
      if (comp->apple2_edge_positions != NULL) {
          free(comp->apple2_edge_positions);
          comp->apple2_edge_positions = NULL;
      }
      if (comp->edge_positions != NULL) {
          free(comp->edge_positions);
          comp->edge_positions = NULL;
      }
      if (comp->coco_edge_positions != NULL) {
          free(comp->coco_edge_positions);
          comp->coco_edge_positions = NULL;
      }
      if (comp->media_path != NULL) {
          free(comp->media_path);
          comp->media_path = NULL;
      }
      if (comp->resolved_wav_path != NULL) {
          free(comp->resolved_wav_path);
          comp->resolved_wav_path = NULL;
      }
      if (comp->atari_cas_event_durations != NULL) {
          free(comp->atari_cas_event_durations);
          comp->atari_cas_event_durations = NULL;
      }
      if (comp->atari_cas_event_bytes != NULL) {
          free(comp->atari_cas_event_bytes);
          comp->atari_cas_event_bytes = NULL;
      }
      if (comp->atari_cas_event_is_gap != NULL) {
          free(comp->atari_cas_event_is_gap);
          comp->atari_cas_event_is_gap = NULL;
      }
      if (comp->bbc_event_durations != NULL) {
          free(comp->bbc_event_durations);
          comp->bbc_event_durations = NULL;
      }
      if (comp->bbc_event_bytes != NULL) {
          free(comp->bbc_event_bytes);
          comp->bbc_event_bytes = NULL;
      }
      (void)cpu;
  callback_handlers:
    load_media: |
      if (argc < 1u || args[0] == 0u) return 0u;
      {
          const char *path = (const char *)(uintptr_t)args[0];
          char wav_path[1024];
          const char *open_path = path;
          FILE *fp = NULL;
          uint8_t *buf = NULL;
          long file_size = 0;
          uint32_t data_offset = 0u;
          uint32_t data_length = 0u;
          uint32_t sample_rate = 0u;
          uint32_t bbc_trace_spb = 0u;
          uint32_t bbc_trace_short_peak = 0u;
          uint32_t bbc_trace_long_peak = 0u;
          uint16_t channels = 0u;
          uint16_t bits_per_sample = 0u;
          const char *dot = strrchr(path, '.');
          if (comp->record_fp != NULL) {
              FILE *old_fp = (FILE *)comp->record_fp;
              uint32_t riff_size = 36u + comp->record_bytes;
              uint32_t data_size = comp->record_bytes;
              fseek(old_fp, 4, SEEK_SET);
              fwrite(&riff_size, 1, 4, old_fp);
              fseek(old_fp, 40, SEEK_SET);
              fwrite(&data_size, 1, 4, old_fp);
              fclose(old_fp);
              comp->record_fp = NULL;
              comp->record_bytes = 0u;
          }
          if (comp->wav_data != NULL) {
              free(comp->wav_data);
              comp->wav_data = NULL;
          }
      if (comp->wav_filtered_mono != NULL) {
          free(comp->wav_filtered_mono);
          comp->wav_filtered_mono = NULL;
      }
      if (comp->direct_edge_positions != NULL) {
          free(comp->direct_edge_positions);
          comp->direct_edge_positions = NULL;
      }
      if (comp->apple2_edge_positions != NULL) {
          free(comp->apple2_edge_positions);
          comp->apple2_edge_positions = NULL;
      }
      if (comp->edge_positions != NULL) {
          free(comp->edge_positions);
          comp->edge_positions = NULL;
      }
      if (comp->coco_edge_positions != NULL) {
          free(comp->coco_edge_positions);
          comp->coco_edge_positions = NULL;
      }
      if (comp->atari_audio_track != NULL) {
          free(comp->atari_audio_track);
          comp->atari_audio_track = NULL;
      }
      if (comp->atari_cas_event_durations != NULL) {
              free(comp->atari_cas_event_durations);
              comp->atari_cas_event_durations = NULL;
          }
          if (comp->atari_cas_event_bytes != NULL) {
              free(comp->atari_cas_event_bytes);
              comp->atari_cas_event_bytes = NULL;
          }
          if (comp->atari_cas_event_is_gap != NULL) {
              free(comp->atari_cas_event_is_gap);
              comp->atari_cas_event_is_gap = NULL;
          }
          if (comp->bbc_event_durations != NULL) {
              free(comp->bbc_event_durations);
              comp->bbc_event_durations = NULL;
          }
          if (comp->bbc_event_bytes != NULL) {
              free(comp->bbc_event_bytes);
              comp->bbc_event_bytes = NULL;
          }
          comp->edge_count = 0u;
          comp->edge_cap = 0u;
          comp->edge_index = 0u;
          comp->edge_initial_level = 0u;
          comp->coco_edge_count = 0u;
          comp->coco_edge_cap = 0u;
          comp->coco_edge_index = 0u;
          comp->coco_edge_initial_level = 0u;
          comp->atari_audio_track_length = 0u;
          comp->atari_audio_track_pos = 0u;
          comp->atari_audio_track_cycle_residue = 0u;
          comp->atari_audio_track_last_cycle = cpu->total_cycles;
          comp->atari_audio_present = 0u;
          comp->atari_cas_event_count = 0u;
          comp->atari_cas_event_cap = 0u;
          comp->bbc_event_count = 0u;
          comp->bbc_event_cap = 0u;
          comp->atari_cas_event_index = 0u;
          comp->atari_cas_event_time_left = 0;
          comp->bbc_event_index = 0u;
          comp->bbc_event_time_left = 0;
          comp->atari_cas_pending_serin = 0u;
          comp->atari_cas_pending_byte = 0xFFu;
          comp->atari_cas_current_kind = 1u;
          comp->atari_cas_current_byte = 0xFFu;
          if (comp->media_path != NULL) {
              free(comp->media_path);
              comp->media_path = NULL;
          }
          if (comp->resolved_wav_path != NULL) {
              free(comp->resolved_wav_path);
              comp->resolved_wav_path = NULL;
          }
          if (dot != NULL && strcmp(dot, ".yaml") == 0) {
              FILE *yf = fopen(path, "r");
              if (yf == NULL) return 0u;
              wav_path[0] = '\0';
              while (fgets(wav_path, sizeof(wav_path), yf) != NULL) {
                  char *s = wav_path;
                  while (*s == ' ' || *s == '\t') s++;
                  if (strncmp(s, "file:", 5) == 0) {
                      char *v = s + 5;
                      while (*v == ' ' || *v == '\t') v++;
                      size_t len = strlen(v);
                      while (len > 0u && (v[len - 1u] == '\n' || v[len - 1u] == '\r' || v[len - 1u] == ' ' || v[len - 1u] == '\t')) {
                          v[--len] = '\0';
                      }
                      if (len > 1u && ((v[0] == '"' && v[len - 1u] == '"') || (v[0] == '\'' && v[len - 1u] == '\''))) {
                          v[len - 1u] = '\0';
                          v++;
                      }
                      {
                          const char *slash = strrchr(path, '/');
                          if (slash != NULL && v[0] != '/') {
                              size_t base_len = (size_t)(slash - path);
                              if (base_len + 1u + strlen(v) + 1u >= sizeof(wav_path)) {
                                  fclose(yf);
                                  return 0u;
                              }
                              memcpy(wav_path, path, base_len);
                              wav_path[base_len] = '/';
                              snprintf(wav_path + base_len + 1u, sizeof(wav_path) - base_len - 1u, "%s", v);
                          } else {
                              snprintf(wav_path, sizeof(wav_path), "%s", v);
                          }
                      }
                      break;
                  }
              }
              fclose(yf);
              if (wav_path[0] == '\0') return 0u;
              open_path = wav_path;
          }
          fp = fopen(open_path, "rb");
          if (fp == NULL) return 0u;
          if (fseek(fp, 0, SEEK_END) != 0) {
              fclose(fp);
              return 0u;
          }
          file_size = ftell(fp);
          if (file_size <= 44) {
              fclose(fp);
              return 0u;
          }
          if (fseek(fp, 0, SEEK_SET) != 0) {
              fclose(fp);
              return 0u;
          }
          buf = (uint8_t *)malloc((size_t)file_size);
          if (buf == NULL) {
              fclose(fp);
              return 0u;
          }
          if (fread(buf, 1, (size_t)file_size, fp) != (size_t)file_size) {
              free(buf);
              fclose(fp);
              return 0u;
          }
          fclose(fp);
          if (memcmp(buf, "RIFF", 4) != 0 || memcmp(buf + 8, "WAVE", 4) != 0) {
              free(buf);
              return 0u;
          }
          {
              uint32_t off = 12u;
              while (off + 8u <= (uint32_t)file_size) {
                  uint32_t chunk_size = (uint32_t)buf[off + 4u] | ((uint32_t)buf[off + 5u] << 8u) | ((uint32_t)buf[off + 6u] << 16u) | ((uint32_t)buf[off + 7u] << 24u);
                  if (off + 8u + chunk_size > (uint32_t)file_size) break;
                  if (memcmp(buf + off, "fmt ", 4) == 0 && chunk_size >= 16u) {
                      uint16_t audio_format = (uint16_t)buf[off + 8u] | (uint16_t)((uint16_t)buf[off + 9u] << 8u);
                      channels = (uint16_t)buf[off + 10u] | (uint16_t)((uint16_t)buf[off + 11u] << 8u);
                      sample_rate = (uint32_t)buf[off + 12u] | ((uint32_t)buf[off + 13u] << 8u) | ((uint32_t)buf[off + 14u] << 16u) | ((uint32_t)buf[off + 15u] << 24u);
                      bits_per_sample = (uint16_t)buf[off + 22u] | (uint16_t)((uint16_t)buf[off + 23u] << 8u);
                      if (audio_format != 1u) {
                          free(buf);
                          return 0u;
                      }
                  } else if (memcmp(buf + off, "data", 4) == 0) {
                      data_offset = off + 8u;
                      data_length = chunk_size;
                  }
                  off += 8u + chunk_size + (chunk_size & 1u);
              }
          }
          if (data_offset == 0u || data_length == 0u || sample_rate == 0u || channels == 0u || (bits_per_sample != 8u && bits_per_sample != 16u)) {
              free(buf);
              return 0u;
