{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM Floppy Source Type Definition",
  "description": "Schema for reusable floppy image source type definitions selected by file extension.",
  "type": "object",
  "required": [
    "metadata",
    "source"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "type",
        "model"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "floppy_source"
          ]
        },
        "model": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "kind",
        "allowed_extensions"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file"
          ]
        },
        "label": {
          "type": "string"
        },
        "source_component": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "allowed_extensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^\\.?[A-Za-z0-9_+\\-]{1,15}$"
          }
        }
      }
    }
  }
}
