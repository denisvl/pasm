{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM System Definition",
  "description": "Schema for system.yaml (runtime/deployment model).",
  "type": "object",
  "required": [
    "metadata",
    "clock_hz",
    "memory"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "System profile name"
        },
        "version": {
          "type": "string",
          "description": "Optional system profile version"
        }
      }
    },
    "clock_hz": {
      "type": "integer",
      "minimum": 1,
      "description": "System clock in Hertz"
    },
    "memory": {
      "type": "object",
      "required": [
        "default_size"
      ],
      "additionalProperties": false,
      "properties": {
        "default_size": {
          "type": "integer",
          "minimum": 1
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "start",
              "size"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "start": {
                "type": "integer",
                "minimum": 0
              },
              "size": {
                "type": "integer",
                "minimum": 0
              },
              "read_write": {
                "type": "boolean"
              },
              "read_only": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pre_fetch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "post_decode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "post_execute": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_read_pre": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_read_post": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_write_pre": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_write_post": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "description": "Free-form integration metadata for future adapters",
      "additionalProperties": true
    }
  }
}
