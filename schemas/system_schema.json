{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM System Definition",
  "description": "Schema for system.yaml (runtime/deployment model).",
  "type": "object",
  "required": [
    "metadata",
    "clock_hz",
    "memory",
    "components",
    "connections"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "System profile name"
        },
        "version": {
          "type": "string",
          "description": "Optional system profile version"
        }
      }
    },
    "clock_hz": {
      "type": "integer",
      "minimum": 1,
      "description": "System clock in Hertz"
    },
    "reset_delay_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Delay applied on each system reset before execution resumes"
    },
    "memory": {
      "type": "object",
      "required": [
        "default_size"
      ],
      "additionalProperties": false,
      "properties": {
        "default_size": {
          "type": "integer",
          "minimum": 1
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "start",
              "size"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "start": {
                "type": "integer",
                "minimum": 0
              },
              "size": {
                "type": "integer",
                "minimum": 0
              },
              "read_write": {
                "type": "boolean"
              },
              "read_only": {
                "type": "boolean"
              }
            }
          }
        },
        "rom_images": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "file",
              "target_region"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "file": {
                "type": "string"
              },
              "target_region": {
                "type": "string"
              },
              "offset": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pre_fetch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "post_decode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "post_execute": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_read_pre": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_read_post": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_write_pre": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "port_write_post": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "description": "Free-form integration metadata for future adapters",
      "additionalProperties": true
    },
    "components": {
      "type": "object",
      "required": [
        "ics",
        "devices",
        "hosts"
      ],
      "additionalProperties": false,
      "properties": {
        "ics": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "devices": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "cartridge": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "object",
            "required": [
              "component",
              "kind",
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "component": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "callback",
                  "signal"
                ]
              },
              "name": {
                "type": "string"
              }
            }
          },
          "to": {
            "type": "object",
            "required": [
              "component",
              "kind",
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "component": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "callback",
                  "handler"
                ]
              },
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sample_rate": {
          "type": "integer",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "s16le",
            "float32"
          ]
        },
        "channels": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        }
      }
    }
  }
}
