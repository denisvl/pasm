{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM Cassette Source Type Definition",
  "description": "Schema for reusable cassette source type definitions such as WAV-backed files or live line-in capture.",
  "type": "object",
  "required": [
    "metadata",
    "source"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "type",
        "model"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "cassette_source"
          ]
        },
        "model": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "kind"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "line_in"
          ]
        },
        "label": {
          "type": "string"
        },
        "source_component": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "allowed_extensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\.?[A-Za-z0-9_+\\-]{1,15}$"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "file"
              }
            }
          },
          "then": {
            "required": [
              "allowed_extensions"
            ]
          }
        }
      ]
    }
  }
}
