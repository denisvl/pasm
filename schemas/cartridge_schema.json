{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM Cartridge Definition",
  "description": "Schema for cartridge mapper definitions (single active cartridge map per run).",
  "type": "object",
  "required": [
    "metadata",
    "state",
    "interfaces",
    "behavior",
    "coding"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "type",
        "model"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "model": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "clock_hz": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "type": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_ *]*$"
          },
          "initial": {
            "type": "string"
          }
        }
      }
    },
    "interfaces": {
      "type": "object",
      "required": [
        "callbacks",
        "handlers",
        "signals"
      ],
      "additionalProperties": false,
      "properties": {
        "callbacks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "returns": {
                "type": "string"
              }
            }
          }
        },
        "handlers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "maps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ports": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "mask",
                  "value"
                ],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "mask": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "value": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            },
            "write": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "mask",
                  "value"
                ],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "mask": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "value": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ranges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "start",
                  "size"
                ],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "start": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "size": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "access": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "read",
                        "write"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "behavior": {
      "type": "object",
      "required": [
        "snippets",
        "callback_handlers",
        "handler_bodies"
      ],
      "additionalProperties": false,
      "properties": {
        "snippets": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "callback_handlers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "handler_bodies": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "coding": {
      "type": "object",
      "required": [
        "headers",
        "include_paths",
        "linked_libraries",
        "library_paths"
      ],
      "additionalProperties": false,
      "properties": {
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "linked_libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "oneOf": [
              {
                "required": [
                  "name"
                ]
              },
              {
                "required": [
                  "path"
                ]
              }
            ]
          }
        },
        "library_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
