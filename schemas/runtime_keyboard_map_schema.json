{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM Runtime Keyboard Map",
  "description": "Runtime keyboard mapping loaded via --keyboard-map.",
  "type": "object",
  "required": [
    "keyboard"
  ],
  "additionalProperties": false,
  "properties": {
    "keyboard": {
      "type": "object",
      "required": [
        "kind",
        "bindings"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "matrix",
            "ascii"
          ]
        },
        "focus_required": {
          "type": "boolean"
        },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "host_key"
            ],
            "additionalProperties": false,
            "properties": {
              "host_key": {
                "type": "string",
                "pattern": "^[A-Z0-9_]+$"
              },
              "presses": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "row",
                    "bit"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "row": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 31
                    },
                    "bit": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 7
                    }
                  }
                }
              },
              "ascii": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "ascii_shift": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "ascii_ctrl": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              }
            }
          }
        }
      }
    }
  }
}
