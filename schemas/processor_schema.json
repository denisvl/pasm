{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PASM Processor Definition",
  "description": "Schema for processor.yaml (CPU semantics).",
  "type": "object",
  "required": [
    "metadata",
    "registers",
    "flags",
    "instructions",
    "coding"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "bits",
        "address_bits",
        "endian",
        "codegen"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Processor name"
        },
        "version": {
          "type": "string",
          "description": "Processor/ISA version"
        },
        "bits": {
          "type": "integer",
          "minimum": 4,
          "maximum": 64,
          "description": "Primary register width"
        },
        "address_bits": {
          "type": "integer",
          "minimum": 8,
          "maximum": 64,
          "description": "Address bus width"
        },
        "endian": {
          "type": "string",
          "enum": [
            "little",
            "big"
          ],
          "description": "Endianness"
        },
        "undefined_opcode_policy": {
          "type": "string",
          "enum": [
            "trap",
            "nop"
          ],
          "description": "Behavior for undefined opcode patterns",
          "default": "trap"
        },
        "codegen": {
          "type": "object",
          "required": [
            "architecture_id",
            "numeric_style",
            "flags_dump_style",
            "decode_quirks",
            "display_kinds_enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "architecture_id": {
              "type": "string",
              "enum": [
                "z80",
                "mos6502",
                "mos6510",
                "mc6809",
                "m68000",
                "ricoh2a03",
                "unknown"
              ]
            },
            "numeric_style": {
              "type": "string",
              "enum": [
                "c_hex",
                "asm_dollar",
                "z80_h"
              ]
            },
            "flags_dump_style": {
              "type": "string",
              "enum": [
                "raw",
                "z80_compact"
              ]
            },
            "decode_quirks": {
              "type": "object",
              "required": [
                "mc6809_indexed_postbyte_length"
              ],
              "additionalProperties": false,
              "properties": {
                "mc6809_indexed_postbyte_length": {
                  "type": "boolean"
                }
              }
            },
            "display_kinds_enabled": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "table",
                  "cc_table",
                  "hex8",
                  "hex16",
                  "hex32",
                  "hex8_plain",
                  "hex16_plain",
                  "hex8_asm",
                  "hex16_asm",
                  "signed8",
                  "signed16",
                  "unsigned",
                  "mc6809_idx",
                  "mc6809_pshs_mask",
                  "mc6809_puls_mask",
                  "mc6809_pshu_mask",
                  "mc6809_pulu_mask"
                ]
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "registers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "bits"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Register name (use R0..R7 for ranges)"
          },
          "display_name": {
            "type": "string",
            "description": "Optional debugger/UI label for the register"
          },
          "type": {
            "type": "string",
            "enum": [
              "general",
              "program_counter",
              "stack_pointer",
              "index",
              "special"
            ]
          },
          "bits": {
            "type": "integer",
            "minimum": 1,
            "maximum": 64
          },
          "parts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "lsb",
                "bits"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                },
                "lsb": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 63
                },
                "bits": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 64
                }
              }
            }
          }
        }
      }
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "bit"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "bit": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "ports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address_bits": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "interrupts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "none",
            "fixed_vector",
            "z80",
            "mos6502",
            "mc6809"
          ],
          "description": "Interrupt dispatch model used by generated runtime"
        },
        "modes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "fixed_vector": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "vector_table": {
          "type": "boolean"
        },
        "vector_size": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "category",
          "encoding",
          "behavior"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z_][A-Z0-9_]*$"
          },
          "display": {
            "type": "string",
            "description": "Optional human-readable instruction text"
          },
          "display_template": {
            "type": "string",
            "description": "Optional operand-aware display template using {field} or {field:formatter} tokens"
          },
          "display_operands": {
            "type": "object",
            "description": "Optional operand rendering specs keyed by decoded field name",
            "additionalProperties": {
              "type": "object",
              "required": [
                "kind"
              ],
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "table",
                    "cc_table",
                    "hex8",
                    "hex16",
                    "hex32",
                    "hex8_plain",
                    "hex16_plain",
                    "hex8_asm",
                    "hex16_asm",
                    "signed8",
                    "signed16",
                    "unsigned",
                    "mc6809_idx",
                    "mc6809_pshs_mask",
                    "mc6809_puls_mask",
                    "mc6809_pshu_mask",
                    "mc6809_pulu_mask"
                  ]
                },
                "table": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "mask": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "category": {
            "type": "string",
            "enum": [
              "arithmetic",
              "logic",
              "data_transfer",
              "control",
              "bit",
              "rotate",
              "misc"
            ]
          },
          "encoding": {
            "type": "object",
            "required": [
              "opcode"
            ],
            "additionalProperties": false,
            "properties": {
              "opcode": {
                "type": "integer",
                "minimum": 0,
                "maximum": 65535
              },
              "mask": {
                "type": "integer",
                "minimum": 0,
                "maximum": 65535
              },
              "prefix": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "subop": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "subop_mask": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "length": {
                "type": "integer",
                "minimum": 1,
                "maximum": 16
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "position"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "position": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 2,
                      "maxItems": 2
                    },
                    "width": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "register",
                        "immediate",
                        "address"
                      ]
                    }
                  }
                }
              }
            }
          },
          "timing_profile": {
            "type": "object",
            "required": [
              "bus_events",
              "total_tstates"
            ],
            "additionalProperties": false,
            "properties": {
              "bus_events": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "kind",
                    "t_offset"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": [
                        "mem_read_opcode",
                        "mem_read_operand",
                        "mem_read",
                        "mem_write",
                        "port_read",
                        "port_write"
                      ]
                    },
                    "t_offset": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                }
              },
              "total_tstates": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "length": {
            "type": "integer",
            "minimum": 1
          },
          "cycles": {
            "type": "integer",
            "minimum": 0
          },
          "behavior": {
            "type": "string",
            "description": "C code that implements the instruction"
          }
        }
      }
    },
    "coding": {
      "type": "object",
      "required": [
        "headers",
        "include_paths",
        "linked_libraries",
        "library_paths"
      ],
      "additionalProperties": false,
      "properties": {
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "linked_libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "oneOf": [
              {
                "required": [
                  "name"
                ]
              },
              {
                "required": [
                  "path"
                ]
              }
            ]
          }
        },
        "library_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
